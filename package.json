{
  "name": "thedimas-website",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "dev:e2e": "next dev --hostname 127.0.0.1 --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run --spec 'cypress/e2e/discovery-files.cy.ts,cypress/e2e/home.cy.ts,cypress/e2e/services.cy.ts,cypress/e2e/content-visibility.cy.ts,cypress/e2e/header-layout.cy.ts,cypress/e2e/blog.cy.ts'",
    "test:e2e": "start-server-and-test dev:e2e http://127.0.0.1:3001 cypress:run",
    "visual:baseline": "CYPRESS_VISUAL_TARGET=baseline cypress run --spec cypress/e2e/visual.cy.ts",
    "visual:current": "CYPRESS_VISUAL_TARGET=current cypress run --spec cypress/e2e/visual.cy.ts",
    "visual:baseline:e2e": "start-server-and-test dev:e2e http://127.0.0.1:3001 visual:baseline",
    "visual:current:e2e": "start-server-and-test dev:e2e http://127.0.0.1:3001 visual:current",
    "visual:compare": "node scripts/compare-visual-snapshots.mjs"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "classnames": "^2.5.1",
    "framer-motion": "^10.17.4",
    "javascript-time-ago": "^2.5.9",
    "next": "14.0.4",
    "popmotion": "^11.0.5",
    "react": "^18",
    "react-dom": "^18",
    "react-icons": "^4.12.0",
    "react-modal": "^3.16.1",
    "react-scroll-parallax": "^3.4.5",
    "react-sparkle": "^2.0.0",
    "react-use": "^17.4.2",
    "splitting": "^1.0.6",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@types/javascript-time-ago": "^2.0.8",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-modal": "^3.16.3",
    "cypress": "^15.18.0",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0",
    "sass": "^1.69.7",
    "start-server-and-test": "^3.0.11",
    "typescript": "^5"
  }
}
